# Runtime output
beast-logs/
*.jsonl
*.jsonl.*

# Python (only `scripts/fetch_plane_shapes.py` remains, as a Docker
# build-time utility — kept so a local venv created to run it doesn't
# pollute the working tree).
__pycache__/
*.py[cod]
.venv/
venv/
.env

# Node (only used for dev — Playwright + node --test; no runtime deps).
node_modules/
package-lock.json

# .NET
bin/
obj/
# IDE workspace state (Visual Studio, Rider).
.vs/
*.user
# Coverage output from `dotnet test --collect:"XPlat Code Coverage"`.
TestResults/
coverage.cobertura.xml

# Playwright artefacts: browser binaries live in ~/.cache, but test
# traces / screenshots / reports land next to the repo.
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Local docker-compose overrides (user-specific ports, coords, SITE_NAME, ...)
docker-compose.override.yml

# Locally-downloaded aircraft DB (baked at image build time).
app/aircraft_db.csv.gz
# Locally-downloaded airport / navaid DBs + tar1090 plane shapes (baked at build time).
app/airports.csv
app/navaids.csv
app/static/tar1090_shapes.js

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store
