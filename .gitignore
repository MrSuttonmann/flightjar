# Runtime output
beast-logs/
*.jsonl
*.jsonl.*

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# Tooling caches
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Node (only used for dev; no runtime deps)
node_modules/
package-lock.json

# .NET build output
bin/
obj/

# Playwright artefacts: browser binaries live in ~/.cache, but test
# traces / screenshots / reports land next to the repo.
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Local docker-compose overrides (user-specific ports, coords, SITE_NAME, ...)
docker-compose.override.yml

# Locally-downloaded aircraft DB (baked at image build time).
app/aircraft_db.csv.gz
# Locally-downloaded airport / navaid DBs + tar1090 plane shapes (baked at build time).
app/airports.csv
app/navaids.csv
app/static/tar1090_shapes.js

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store
